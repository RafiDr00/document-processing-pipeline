# ──────────────────────────────────────────────────
#  Environment Variables — Example Configuration
#  Copy to .env and customize for your environment
# ──────────────────────────────────────────────────

# ── Application ──
APP_NAME=Document Processing Pipeline
APP_VERSION=2.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ── API ──
API_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# ── Security ──
API_KEY=                          # Leave empty to disable auth; set a strong key in production
RATE_LIMIT_REQUESTS=120           # Max requests per window
RATE_LIMIT_WINDOW_SECONDS=60     # Sliding window size

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docpipeline
DB_POOL_SIZE=5                    # Connection pool core size
DB_MAX_OVERFLOW=10                # Extra connections under load

# ── Redis (Queue + Rate Limiting) ──
REDIS_URL=redis://localhost:6379/0   # Leave empty to use in-memory fallback

# ── File Storage ──
UPLOAD_DIR=uploads
EXPORT_DIR=exports
MAX_UPLOAD_SIZE_MB=50
STORAGE_BACKEND=local             # local | s3

# S3 settings (only when STORAGE_BACKEND=s3)
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── PDF Processing ──
OCR_LANG=eng
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.0
CHUNK_SIZE_PAGES=50               # Pages per processing chunk

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=text                   # text | json
